FROM eclipse-temurin:21-jdk-alpine
RUN addgroup -S biar && adduser -S biar -G biar
WORKDIR /app
ENV MAVEN_OPTS=-Dmaven.repo.local=/app/.m2
COPY .mvn .mvn
COPY mvnw pom.xml ./
RUN chmod +x mvnw && ./mvnw dependency:go-offline -q
RUN mkdir -p /data/exports /app/.m2 && chown -R biar:biar /data/exports /app/.m2
RUN chown -R biar:biar /app
USER biar
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=5 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/actuator/health || exit 1
ENTRYPOINT ["./mvnw", "spring-boot:run", "-Dspring-boot.run.profiles=dev"]